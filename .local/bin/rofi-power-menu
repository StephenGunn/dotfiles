#!/usr/bin/env bash
# Rofi Power Menu with Suspend option

# Check display state
if [[ -f /tmp/display-off ]]; then
    DISPLAY_LABEL="ůįõß Display On"
else
    DISPLAY_LABEL="ůį∂ź Display Off"
fi

options="$DISPLAY_LABEL\nůįí≤ Suspend\nůįćÉ Logout\nůįúČ Restart\nůįź• Shutdown"

chosen=$(echo -e "$options" | rofi -dmenu -i -p "Power" -theme-str 'window {width: 250px;}')

case $chosen in
    "$DISPLAY_LABEL")
        ~/dotfiles/scripts/display-toggle.sh
        ;;
    "ůįí≤ Suspend")
        systemctl suspend
        ;;
    "ůįćÉ Logout")
        hyprctl dispatch exit
        ;;
    "ůįúČ Restart")
        systemctl reboot
        ;;
    "ůįź• Shutdown")
        systemctl poweroff
        ;;
esac
